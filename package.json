{
  "name": "vercel-minimax-ai-provider",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "author": "MiniMax",
  "description": "Vercel AI Provider for running MiniMax AI models",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "pnpm clean && tsup",
    "build:watch": "pnpm clean && tsup -d --watch",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prettier-check": "prettier --check \"./**/*.ts*\"",
    "prepare": "tsup",
    "test": "pnpm test:node && pnpm test:edge",
    "test:edge": "vitest --config vitest.edge.config.mjs --run",
    "test:node": "vitest --config vitest.node.config.mjs --run",
    "ci:release": "pnpm clean && pnpm build && changeset publish",
    "ci:version": "changeset version && pnpm install --no-frozen-lockfile"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.69",
    "@ai-sdk/provider": "3.0.8",
    "@ai-sdk/provider-utils": "4.0.23"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.30.1",
    "@types/node": "20.17.24",
    "@vitest/ui": "^3.0.5",
    "ai": "^6.0.162",
    "eslint": "^9.19.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsup": "^8",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.48.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "zod": "^3.25.76 || ^4.1.8"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "homepage": "https://github.com/MiniMax-AI/vercel-minimax-ai-provider",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MiniMax-AI/vercel-minimax-ai-provider.git"
  },
  "bugs": {
    "url": "https://github.com/MiniMax-AI/vercel-minimax-ai-provider/issues"
  },
  "keywords": [
    "minimax",
    "ai",
    "provider",
    "vercel-ai",
    "vercel",
    "ai-sdk"
  ]
}
